{
  "name": "@clipped-page/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n css,worker -c blue,green \"npm:dev:css\" \"npm:dev:worker\"",
    "dev:css": "tailwindcss -i ./src/styles.input.css -o ./public/styles.css --watch",
    "dev:worker": "wrangler dev",
    "build:css": "tailwindcss -i ./src/styles.input.css -o ./public/styles.css --minify",
    "build": "pnpm build:css && wrangler deploy --dry-run --outdir=dist",
    "deploy": "pnpm build:css && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clipped-page/shared": "workspace:*",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@tailwindcss/cli": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
